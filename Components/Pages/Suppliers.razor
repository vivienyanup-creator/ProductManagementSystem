@page "/suppliers"
@attribute [Authorize]
@inject ISupplierService SupplierService
@inject ISnackbar Snackbar

<PageTitle>Supplier Management</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">Supplier Management</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenAddDialog" Class="mb-4">Add Supplier</MudButton>

<MudTable T="Supplier" Items="_suppliers" Hover="true" Striped="true"
          Loading="_loading" Bordered="true">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>Name</MudTh><MudTh>Contact Person</MudTh>
        <MudTh>Email</MudTh><MudTh>Phone</MudTh><MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Contact Person">@context.ContactPerson</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Phone">@context.Phone</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Warning"
                           OnClick="() => OpenEditDialog(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           OnClick="() => DeleteSupplier(context.Id)" />
        </MudTd>
    </RowTemplate>
</MudTable>

@if (_dialogOpen)
{
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                @(_editId == 0 ? "Add Supplier" : "Edit Supplier")
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.Name" Label="Name"
                                  Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_form.ContactPerson"
                                  Label="Contact Person" Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_form.Email" Label="Email"
                                  Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_form.Phone" Label="Phone"
                                  Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_form.Address" Label="Address"
                                  Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => _dialogOpen = false">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveSupplier">Save</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    List<Supplier> _suppliers = new();
    bool _loading = true, _dialogOpen = false;
    int _editId = 0;
    Supplier _form = new();

    protected override async Task OnInitializedAsync()
        => await LoadSuppliers();

    async Task LoadSuppliers()
    {
        _loading = true;
        _suppliers = await SupplierService.GetSuppliersAsync();
        _loading = false;
    }

    void OpenAddDialog()
    { _editId = 0; _form = new(); _dialogOpen = true; }

    void OpenEditDialog(Supplier s)
    {
        _editId = s.Id;
        _form = new Supplier
        {
            Name = s.Name,
            ContactPerson = s.ContactPerson,
            Email = s.Email,
            Phone = s.Phone,
            Address = s.Address
        };
        _dialogOpen = true;
    }

    async Task SaveSupplier()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Name is required.", Severity.Error);
            return;
        }
        if (_editId == 0)
        {
            await SupplierService.CreateSupplierAsync(_form);
            Snackbar.Add("Supplier added!", Severity.Success);
        }
        else
        {
            _form.Id = _editId;
            await SupplierService.UpdateSupplierAsync(_form);
            Snackbar.Add("Supplier updated!", Severity.Info);
        }
        _dialogOpen = false;
        await LoadSuppliers();
    }

    async Task DeleteSupplier(int id)
    {
        await SupplierService.DeleteSupplierAsync(id);
        Snackbar.Add("Supplier deleted.", Severity.Warning);
        await LoadSuppliers();
    }
}
